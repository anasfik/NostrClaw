{
  "nodeEnv": "development",
  "logLevel": "info",
  "logFilePath": "./data/log.txt",
  "dbPath": "./data/nostr-mind.sqlite",
  "nostrRelays": [
    "wss://relay.damus.io",
    "wss://relay.primal.net",
    "wss://nos.lol"
  ],
  "ai": {
    "provider": "ollama",
    "fallbackProviders": ["openai", "openrouter", "gemini"],
    "rpm": 20,
    "ollama": {
      "baseUrl": "http://localhost:11434",
      "model": "llama3.2"
    },
    "openai": {
      "apiKey": "replace-with-openai-key",
      "model": "gpt-4.1-mini"
    },
    "openrouter": {
      "apiKey": "replace-with-openrouter-key",
      "model": "openai/gpt-4o-mini"
    },
    "gemini": {
      "apiKey": "replace-with-gemini-key",
      "model": "gemini-2.5-flash"
    }
  },
  "notifications": {
    "recipientNpub": "npub1replacewithrecipient"
  },
  "dashboard": {
    "enabled": true,
    "port": 3000,
    "host": "127.0.0.1"
  },
  "watchlists": [
    {
      "id": "bitcoin-l2",
      "name": "Bitcoin L2 Discussions",
      "prompt": "Alert me about significant discussions around Bitcoin L2s and tell me why they matter.",
      "active": true,
      "messageTemplate": "🔔 {{watchlist.name}}\n\n{{ai.message}}\n\nScore: {{ai.score}}\nEvent: {{event.link}}\nAuthor: {{event.author_link}}\n\nPreview:\n{{event.content_preview}}",
      "filters": {
        "keywords": ["bitcoin", "btc", "l2", "lightning", "ark"],
        "kinds": [1],
        "since": 1735689600,
        "limit": 50,
        "tags": {
          "t": ["bitcoin", "lightning"]
        }
      }
    },
    {
      "id": "nostrmind-mentions",
      "name": "NostrMind Mentions",
      "prompt": "Notify me about strong mentions of NostrMind, Nostr Mind, or related tooling.",
      "active": true,
      "filters": {
        "keywords": ["nostrmind", "nostr mind", "nostr-mind"],
        "kinds": [1],
        "since": 1735689600,
        "limit": 50
      }
    }
  ]
}
